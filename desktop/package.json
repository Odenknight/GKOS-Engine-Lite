{
  "name": "gkos-engine-desktop",
  "private": true,
  "version": "0.1.0",
  "description": "GKOS Engine Desktop — Tauri 2 tray shell for the GKOS engine sidecar (loopback-only, read-only).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "build:test": "tsc -p tsconfig.test.json && node -e \"require('fs').writeFileSync('dist-test/package.json','{\\\"type\\\":\\\"commonjs\\\"}')\"",
    "pretest": "npm run build:test",
    "test": "node --test \"test/*.test.mjs\"",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-shell": "^2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "typescript": "^5.6.0",
    "vite": "^5.4.0"
  }
}
