{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist-test",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2022"],
    "verbatimModuleSyntax": false,
    "isolatedModules": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": ["src/strings.ts", "src/snippets.ts", "src/settings-schema.ts", "src/status.ts"]
}
